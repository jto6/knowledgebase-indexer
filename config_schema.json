{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["directories", "output"],
  "properties": {
    "directories": {
      "type": "object",
      "required": ["include"],
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "keywords": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": ["freeplane", "markdown"],
          "default": "freeplane"
        },
        "partition_by_domain": {
          "enum": ["auto", "on", "off"],
          "description": "Partition the index by domain: auto (if any file has a domain) | on | off."
        },
        "views": {
          "type": "object",
          "description": "Per-view emission override: auto (renderer default) | on | off.",
          "additionalProperties": false,
          "properties": {
            "file_system": {"enum": ["auto", "on", "off"]},
            "keyword": {"enum": ["auto", "on", "off"]},
            "tag": {"enum": ["auto", "on", "off"]},
            "word": {"enum": ["auto", "on", "off"]},
            "dependencies": {"enum": ["auto", "on", "off"]},
            "glossary": {"enum": ["auto", "on", "off"]}
          }
        }
      }
    },
    "types": {
      "type": "object",
      "additionalProperties": false,
      "description": "Select which built-in file types to index (card, markdown, freeplane). Handlers are built in; the config only includes/excludes them by name. A file is classified by its most-specific type (e.g. .kb.md is a card, not markdown).",
      "properties": {
        "include": {
          "type": "array",
          "items": {"enum": ["card", "markdown", "freeplane"]}
        },
        "exclude": {
          "type": "array",
          "items": {"enum": ["card", "markdown", "freeplane"]}
        }
      }
    }
  }
}
